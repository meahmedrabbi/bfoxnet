# Backend API URL
# For local development, use: http://localhost:8000
# For production with proxy, use: /api/proxy (to proxy to your VPS)
# For production without proxy, use: https://your-backend-url.com
NEXT_PUBLIC_API_URL=http://localhost:8000

# Backend VPS URL (server-side only, used by proxy)
# Only needed if using the /api/proxy route
# This can be HTTP since it's server-to-server communication
BACKEND_URL=http://62.171.183.44:8000
